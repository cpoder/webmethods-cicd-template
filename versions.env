# webMethods Microservice CI/CD Pipeline - Tool Versions
# This file pins all tool versions used by CI workflows and helper scripts.
# Source in bash: set -a && . versions.env && set +a
# Load in GitHub Actions: cat versions.env >> $GITHUB_ENV

# IBM webMethods Microservices Runtime
# Pulled from the IBM webMethods Container Registry. Auth is a registry
# token minted at https://containers.webmethods.io (sign in with IBMid;
# w3id SSO for IBM employees), then:
#   docker login -u <token-name> -p <token-password> ibmwebmethods.azurecr.io
# Tag convention (per IBM docs):
#   :12.1       -> latest fix on the 12.1 line
#   :12.1.0.X   -> a specific core fix (e.g. 12.1.0.1 = Core Fix 1)
# Pin to a fix-level tag in production; the floating :12.1 is for local
# experimentation only.
MSR_VERSION=12.1
MSR_BASE_IMAGE=ibmwebmethods.azurecr.io/webmethods-microservicesruntime

# webMethods MCP Server (cpoder/wm-mcp-server)
# Check latest release at: https://github.com/cpoder/wm-mcp-server/releases
WM_MCP_SERVER_VERSION=v1.0.0

# webMethods Integration Test Suite (UTF)
# REQUIRED for the test variant of docker/base/Dockerfile.
# No default: pin to your IBM Passport download URL or your corporate
# mirror copy. The build will hard-fail with a clear error if this is
# unset (Dockerfile guards on it). The legacy empower.softwareag.com
# URL is dead under IBM; replace before first build.
WM_TEST_SUITE_VERSION=12.1
WM_TEST_SUITE_INSTALLER_URL=

# Java Runtime
JAVA_VERSION=17

# Apache Ant (used by Test Suite Executor)
ANT_VERSION=1.10.14

# Docker Buildx
DOCKER_BUILDX_VERSION=v0.13.0

# Helm
HELM_VERSION=3.14.0

# Security gates (Task 5.1)
# gitleaks: secret scanner run over the PR diff for fail-fast feedback
# trivy:    filesystem CVE scanner; HIGH/CRITICAL is a hard PR gate
GITLEAKS_VERSION=8.21.2
TRIVY_VERSION=0.58.1
