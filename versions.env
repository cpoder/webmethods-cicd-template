# webMethods Microservice CI/CD Pipeline - Tool Versions
# This file pins all tool versions used by CI workflows and helper scripts.
# Source in bash: set -a && . versions.env && set +a
# Load in GitHub Actions: cat versions.env >> $GITHUB_ENV

# webMethods Microservices Runtime
MSR_VERSION=11.1.0
MSR_BASE_IMAGE=ibmcom/webmethods-microservicesruntime

# webMethods MCP Server (cpoder/wm-mcp-server)
# Check latest release at: https://github.com/cpoder/wm-mcp-server/releases
WM_MCP_SERVER_VERSION=v1.0.0

# webMethods Integration Test Suite (UTF)
WM_TEST_SUITE_VERSION=11.1.0
# Note: Replace with actual IBM Passport URL or corporate mirror
WM_TEST_SUITE_INSTALLER_URL=https://empower.softwareag.com/downloads/wm-test-suite-11.1.0-installer.zip

# Java Runtime
JAVA_VERSION=17

# Apache Ant (used by Test Suite Executor)
ANT_VERSION=1.10.14

# Docker Buildx
DOCKER_BUILDX_VERSION=v0.13.0

# Helm
HELM_VERSION=3.14.0

# Security gates (Task 5.1)
# gitleaks: secret scanner run over the PR diff for fail-fast feedback
# trivy:    filesystem CVE scanner; HIGH/CRITICAL is a hard PR gate
GITLEAKS_VERSION=8.21.2
TRIVY_VERSION=0.58.1
