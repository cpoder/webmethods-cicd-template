# CODEOWNERS file for webMethods CI/CD repository
# Define code ownership for automatic review assignment
# See: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Default owners for everything in the repo
* @integration-team

# Package owners
/packages/ @integration-team @package-maintainers

# Configuration owners
/config/ @devops-team @integration-team

# Production configuration is the highest-blast-radius surface in
# this repo: changes are picked up by `apply-config.sh --env prod`
# and pushed to live MSR instances. Listing two distinct teams here
# makes `require_code_owner_reviews:true` (set by
# scripts/setup/branch-protection.sh) demand at least one approval
# from EACH team -- effectively >= 2 approvals for any PR touching
# /config/prod/. See docs/branch-protection.md.
/config/prod/ @devops-team @release-managers

# Docker and deployment
/docker/ @devops-team
/helm/ @devops-team @kubernetes-team

# CI/CD workflows
/.github/workflows/ @devops-team

# Testing
/tests/ @qa-team @integration-team

# Scripts
/scripts/ @devops-team

# Documentation
/docs/ @tech-writers @integration-team
/README.md @tech-writers
