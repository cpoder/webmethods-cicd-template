          "editorMode": "code",
          "expr": "max(sum by (pod) (jvm_memory_used_bytes{area=\"heap\", job=~\"$job\", namespace=~\"$namespace\"})) / max(sum by (pod) (jvm_memory_max_bytes{area=\"heap\", job=~\"$job\", namespace=~\"$namespace\"}))",
