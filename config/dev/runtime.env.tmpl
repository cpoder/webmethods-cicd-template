# Runtime environment for the dev wm-svc container.
#
# Resolved at deploy time by scripts/lib/render-properties.sh:
# every ${NAME} placeholder is replaced with the value of env var
# NAME. Unset / empty env vars abort the deploy -- there is no
# silent fallback, deliberately. Comment lines are passed through
# verbatim, so this file can document its own placeholder syntax
# without the renderer trying to expand it.
#
# Naming follows docs/secrets.md. CI populates the env at the
# `appleboy/ssh-action` boundary from GitHub Environment Secrets.
#
# IMPORTANT: this file becomes the container's `--env-file` and is
# read by Docker line-by-line as KEY=VAL pairs. No shell quoting,
# no interpolation, no comments inside values.

# ---- IS administrator credentials (used by apply-config + ops) -------
SAG_IS_USER_ADMINISTRATOR_PASSWORD=${MSR_ADMIN_PASSWORD}

# ---- JVM tuning ------------------------------------------------------
# Conservative dev defaults; bump for prod via prod runtime.env.tmpl.
JAVA_MIN_MEM=512m
JAVA_MAX_MEM=2048m

# ---- Logging --------------------------------------------------------
# IS reads SAG_IS_LOG_LEVEL on startup and applies it to the root
# logger. DEBUG in dev for troubleshooting; INFO in prod.
SAG_IS_LOG_LEVEL=DEBUG

# ---- Tracing ---------------------------------------------------------
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_SERVICE_NAME=wm-svc-dev

# ---- License (if the base image needs runtime-license injection) ----
# Empty string is rejected by render-properties.sh, which is
# intentional -- a missing license is a Friday-afternoon failure.
SAG_LICENSE_KEY=${SAG_LICENSE_KEY_DEV}
