# Runtime environment for the test wm-svc container.
#
# Resolved by scripts/lib/render-properties.sh (${NAME} -> $NAME from
# the process env). Comment lines are passed through verbatim.
#
# CI populates the env at the appleboy/ssh-action boundary from the
# `test` GitHub Environment's secrets. Naming follows docs/secrets.md.

# ---- IS administrator credentials -----------------------------------
SAG_IS_USER_ADMINISTRATOR_PASSWORD=${MSR_ADMIN_PASSWORD}

# ---- JVM tuning -----------------------------------------------------
# Slightly larger than dev to handle the integration test load.
JAVA_MIN_MEM=768m
JAVA_MAX_MEM=2560m

# ---- Logging --------------------------------------------------------
SAG_IS_LOG_LEVEL=INFO

# ---- Tracing --------------------------------------------------------
OTEL_TRACES_SAMPLER_ARG=0.5
OTEL_SERVICE_NAME=wm-svc-test

# ---- License --------------------------------------------------------
SAG_LICENSE_KEY=${SAG_LICENSE_KEY_TEST}
