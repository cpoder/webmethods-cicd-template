<?xml version="1.0" encoding="UTF-8"?>
<!--
    GreetMissingName - DELIBERATELY FAILING test case.

    Used to demonstrate (acceptance criterion a) that scripts/test-unit.sh
    exits 1 on a failed assertion. To satisfy the second half of the
    criterion ("exits 0 once it's fixed"), update the expected greeting
    below to "Hello, !" -- which is what the service emits when the name
    pipeline value is empty.

    Do NOT delete this case to make CI green: the failing case is the
    canary that proves the headless runner is wired up.
-->
<wmTestCase name="GreetMissingName" version="1.0">
    <description>greet("") - intentionally asserts the wrong greeting so the runner reports a failure.</description>
    <serviceUnderTest>hello.world:greet</serviceUnderTest>
    <inputPipeline format="xml"><![CDATA[
<IData>
    <value name="name"></value>
</IData>
    ]]></inputPipeline>
    <expectedOutput>
        <!-- Wrong on purpose. Real output is "Hello, !". -->
        <assertion type="equals" path="greeting" expected="Hello, stranger!"/>
    </expectedOutput>
    <mocks/>
</wmTestCase>
